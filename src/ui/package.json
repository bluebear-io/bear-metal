{
  "name": "bear-metal-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5273",
    "build": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false && tsc -p tsconfig.node.json --noEmit --pretty false",
    "test": "vitest run"
  },
  "dependencies": {
    "@tanstack/react-query": "5.100.10",
    "lucide-react": "0.544.0",
    "react": "19.1.2",
    "react-dom": "19.1.2",
    "react-router-dom": "6.30.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.1",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "22.19.19",
    "@types/react": "19.1.13",
    "@types/react-dom": "19.1.9",
    "@vitejs/plugin-react": "5.1.2",
    "jsdom": "27.0.1",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.2",
    "vite": "7.3.3",
    "vitest": "3.2.6"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
