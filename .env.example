# Linear
LINEAR_API_TOKEN=          # required — Linear API token (assignee resolved automatically via viewer query)

# GitHub (App-based auth — the client acts as the installation and scans every
# repo the installation can access)
GITHUB_APP_ID=                  # required — numeric GitHub App id
GITHUB_APP_PRIVATE_KEY=         # required — App private key PEM (use \n for newlines)
GITHUB_APP_INSTALLATION_ID=     # required — numeric installation id

# Manager
DATABASE_URL=             # optional — sqlite:./bear-metal.sqlite when empty; postgres://... for Postgres
WORKER_CONCURRENCY=5      # optional — max tickets worked in parallel
POLL_INTERVAL_MS=60000    # optional — poll cadence in ms
TASK_HEARTBEAT_INTERVAL_MS=30000  # optional — worker heartbeat cadence for stale-task recovery
TASK_STALE_AFTER_MS=300000        # optional — recover a task whose worker hasn't heartbeat in this long
TASK_MAX_RECLAIMS=3              # optional — abandon a row after this many recoveries
MAX_ITERATIONS=50         # optional — max dispatch cycles per ticket before handing back to human
MAX_WORKER_TIME_MS=7200000  # optional — max wall-clock time in ms for a single worker session (default: 2 hours)
MAX_WORKER_TOKENS=20000000  # optional — max tokens consumed in a single worker session (default: 20M)
BACKEND_PORT=3100         # optional — UI and API server port
LOG_LEVEL=info            # optional — pino log level
LOG_PRETTY=false          # optional — colorized, human-readable logs (dev); JSON when false
API_ONLY=false            # optional — start only the UI/API server; disables environment builder, scheduler, and worker

# LLM credentials — at least one must be set. bear-metal passes whichever keys are
# present to the Pi agent, which picks the model automatically.
ANTHROPIC_API_KEY=   # Anthropic (Claude)
OPENAI_API_KEY=      # OpenAI (GPT-4o, o1, ...)
GOOGLE_API_KEY=      # Google (Gemini)

# Workspace builder — exactly one must be set (mutually exclusive).
#
# WORKSPACE_BUILDER_COMMAND: inline bash script. Bear-metal writes it to a temp
#   file and executes it. Good for one-liners or short scripts.
#   Example (single repo):
#     WORKSPACE_BUILDER_COMMAND=git clone git@github.com:your-user/your-repo "$AGENT_WORKDIR"
#
# WORKSPACE_BUILDER_PATH: path to an executable script file (mounted or baked into
#   a custom image). Good for complex multi-repo or dynamic-routing logic.
#   Example: WORKSPACE_BUILDER_PATH=/scripts/build-workspace.sh
#
# The builder receives AGENT_WORKDIR, TICKET_ID, TICKET_TITLE, TICKET_URL,
# TICKET_TEAM, TICKET_TAGS (comma-separated labels), and TICKET_DESCRIPTION.
# It must populate AGENT_WORKDIR and exit 0 on success.
WORKSPACE_BUILDER_COMMAND=    # required if WORKSPACE_BUILDER_PATH is not set
WORKSPACE_BUILDER_PATH=       # required if WORKSPACE_BUILDER_COMMAND is not set

# Worker environment builder — optional, mutually exclusive.
#
# Runs ONCE at process startup, before the scheduler and task worker start,
# inside the already-running Bear Metal process/container. Use it to install
# language toolchains, package managers, OS libs, or CLIs that your workspace
# builder or the coding agent will need (e.g. Go, Rust, Python, pnpm).
#
# Distinct from WORKSPACE_BUILDER_* above, which runs per ticket inside
# AGENT_WORKDIR. This one runs in the Bear Metal process environment and is
# NOT scoped to AGENT_WORKDIR.
#
# If neither is set, no environment preparation runs (default).
# If both are set, startup fails with a configuration error.
# If the builder exits non-zero, startup fails and no tickets are picked up.
#
# Example (inline): install Go
#   WORKER_ENVIRONMENT_BUILDER_COMMAND=curl -fsSL https://go.dev/dl/go1.23.4.linux-amd64.tar.gz | tar -C /usr/local -xz && ln -sf /usr/local/go/bin/go /usr/local/bin/go
# Example (script):
#   WORKER_ENVIRONMENT_BUILDER_PATH=/scripts/install-toolchains.sh
WORKER_ENVIRONMENT_BUILDER_COMMAND=     # optional
WORKER_ENVIRONMENT_BUILDER_PATH=        # optional — mutually exclusive with WORKER_ENVIRONMENT_BUILDER_COMMAND

# Custom system prompt (optional). Inject operator-specific instructions into the agent prompt.
# Set at most one. SYSTEM_PROMPT_PATH reads a file; SYSTEM_PROMPT is inline content.
# Tip: create system-prompt.md at the repo root (it is gitignored) and set:
#   SYSTEM_PROMPT_PATH=./system-prompt.md
SYSTEM_PROMPT_PATH=               # optional
# SYSTEM_PROMPT=                  # optional — mutually exclusive with SYSTEM_PROMPT_PATH

# Slack notifications (optional). When both are set, the worker posts a message
# to the channel whenever it opens or updates a PR. Set both or leave both empty.
SLACK_BOT_TOKEN=                # optional — Slack bot OAuth token (xoxb-...)
SLACK_NOTIFICATION_CHANNEL=     # optional — channel id (e.g. C0123456789) or #channel-name
