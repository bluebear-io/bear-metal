# Linear
LINEAR_API_TOKEN=          # required — Linear API token
LINEAR_LABEL=bear-metal    # optional — label used to filter tickets

# GitHub (App-based auth — the client acts as the installation and scans every
# repo the installation can access)
GITHUB_APP_ID=                  # required — numeric GitHub App id
GITHUB_APP_PRIVATE_KEY=         # required — App private key PEM (use \n for newlines)
GITHUB_APP_INSTALLATION_ID=     # required — numeric installation id

# Manager
WORKER_CONCURRENCY=2      # optional — max tickets worked in parallel
POLL_INTERVAL_MS=60000    # optional — poll cadence in ms
PORT=3000                 # optional — health server port
LOG_LEVEL=info            # optional — pino log level
LOG_PRETTY=false          # optional — colorized, human-readable logs (dev); JSON when false

# Database (worker task tracking)
# If DATABASE_URL is set, use a Postgres server. Otherwise fall back to a local
# sqlite file at DATABASE_PATH (default: ./bear-metal.sqlite).
DATABASE_URL=             # optional — postgres://user:pass@host:port/dbname
DATABASE_PATH=            # optional — sqlite file path (used when DATABASE_URL is unset)
