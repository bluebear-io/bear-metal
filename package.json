{
  "name": "bear-metal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "dist/manager/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/manager/index.js",
    "dev": "tsx watch src/manager/index.ts",
    "dev:backend": "tsx watch src/backend/index.ts",
    "start:backend": "node dist/backend/index.js",
    "seed:mock": "tsx src/backend/mock/seed.ts",
    "db:generate": "drizzle-kit generate",
    "test": "vitest run"
  },
  "dependencies": {
    "@linear/sdk": "84.0.0",
    "@octokit/rest": "22.0.1",
    "better-sqlite3": "12.10.0",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "express": "4.22.2",
    "p-queue": "9.2.0",
    "pino": "10.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/express": "4.17.25",
    "@types/node": "22.19.19",
    "@types/supertest": "7.2.0",
    "drizzle-kit": "0.31.10",
    "supertest": "7.2.2",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
